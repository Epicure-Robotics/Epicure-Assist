# Epicure Assist ‚Äî minimal env template (see README for staging vs prod).
# Copy to `.env.local`. Use `KEY=value` only (not `KEY:`). Omit optional keys or leave unset.
# Load order (later wins): `.env.production` ‚Üí `.env.development.local` ‚Üí `.env.local`

# --- Epicure ---
EPICURE_DEPLOYMENT=local
# EPICURE_PRIMARY_SUPPORT_EMAIL=connect@epicurerobotics.com

# --- AI (required) ---
# OPENAI_API_KEY=

# --- Supabase (required for hosted DB) ---
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# AUTH_URL=https://your-app.example
# Optional: if pg_cron cannot reach AUTH_URL (rare). Local Docker DB + app on host uses host.docker.internal:3010 when POSTGRES_URL is localhost.
# JOB_WORKER_URL=https://your-app.example

# --- Postgres: pooler + direct, same project (Supabase ‚Üí Database) ---
# POSTGRES_URL=postgresql://...
# POSTGRES_URL_NON_POOLING=postgresql://...
# LOCAL_SUPABASE_DB_PORT=54322

# --- Gmail + Pub/Sub (ingestion) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_PUBSUB_TOPIC_NAME=
# GOOGLE_PUBSUB_CLAIM_EMAIL=

# --- Seed / admin (comma-separated) ---
# INITIAL_USER_EMAILS=epicure-seed@example.com

# --- Optional / not used by default Epicure flow ---
# DATABASE_URL=          # drizzle alias; empty unsets
# RESEND_API_KEY=
# NEXT_PUBLIC_SENTRY_DSN=
# DRIZZLE_LOGGING=true
